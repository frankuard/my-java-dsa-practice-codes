package javaDSA;


// PRINTING BUTTERLFY PATTERN
public class number10 {

	public static void main(String[] args) {
		
		int n = 5;
		
		// FIRST HALF: UPPER HALF
		for (int i=1; i<=n; i++) {
			
			// FIRST PART
			for (int j=1;j<=i;j++){
				
				System.out.print("*");
			}
			
			// SPACES
			
			int spaces = 2* (n-i);
			
			for (int j=1; j<=spaces; j++){
				
				System.out.print(" ");
			}
			
			// 2nd Part
			
			for (int j=1; j<=i; j++) {
				System.out.print("*");
			}
			System.out.println();
		}
	
		// SECOND HALF - LOWER HALF
		for (int i=n; i>=1;i--) {
			
			// FIRST PART
			for (int j=1; j<=i;j++) {
				System.out.print("*");
			}
			int spaces = 2* (n-i);
			
			for (int j=1; j<=spaces; j++) {
				System.out.print(" ");
			}
		}
	}
 }
