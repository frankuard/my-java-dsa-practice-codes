package javaDSA;

// PRINTING INVERTED HALF PYRAMID (rotated by 180 degree)
public class number5 {

	public static void main(String[] args) {
		
		int n = 4;
		
		for (int i=1; i<=n; i++) {
			
			for (int j=1;j<=n-i;i++) {
					System.out.print(" ");
			}
			for (int j=1; j<=i; j++) {
				System.out.println("*");
			}
			System.out.println();
		}
	}
}
