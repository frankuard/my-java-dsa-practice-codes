package javaDSA;
import java.util.*;

public class string {

	public static void main(String[] args) {
		
		// STRING DECLARATION AND DEFINITON
		
		String value = "Hello World";
		
			String anotherValue = "Hello 2D World";
			
		// INITALIZING SCANNER
		
			Scanner scanner = new Scanner(System.in);
			
		// ASKING USER FOR DECLARATION 
			
			System.out.println("Enter your name:");
			
			String name = scanner.next();
			
			System.out.println(name);
			System.out.println(value);
			System.out.println(anotherValue);
		
			
	// CONCANTENATION 
			
			String firstName ="Petah";
			String lastName = "Parkha";
			String fullName = firstName +" "+ lastName;
			System.out.println(fullName);
			
			System.out.println(fullName.length());
			
			
	// COMPARE
			
			// IF FIRSTNAME  > LASTNAME : + VE VALUE
			// IF FIRSTNAME  = LASTNAME : 0 VALUE
			// IF FIRSTNAME  < LASTNAME : - VE VALUE
			
			if (firstName.compareTo(lastName) == 0) {
				System.out.println("Strings are equal");
			}
			else {
				System.out.println("Strings are not equal");
			}
			
			// WE USE COMPARE TO INSTEAD OF JUST == BECUASE SOEMTIMES == FAILS TO PROCESS
			
	// CHARACTER INDEX (charAt)
			
			for(int i= 0; i<fullName.length();i++) {
				System.out.println(fullName.charAt(i));
			}
			
		
	// CHECKING FOR A SPECIFIC INDEX
			
			System.out.println("Enter the keyword you wanna find:");
			char indexValue = scanner.next().charAt(0);
			
			for(int i=0;i<fullName.length();i++) {
				if (indexValue == fullName.charAt(i)) {
					System.out.println("The keyword "+ indexValue+ " is at "+i);
				}
				
			}
	}
	
}
